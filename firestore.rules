rules_version = '2';

// Saved scenarios are shared across every browser hitting the deployed app.
// No authentication required — anyone reaching the site can read and write
// the `scenarios` collection. Tighten these rules (e.g. require Firebase Auth
// + match request.auth.uid) if/when scope changes.
service cloud.firestore {
  match /databases/{database}/documents {
    match /scenarios/{scenarioId} {
      allow read: if true;
      // Validate the document shape on write to keep Firestore from being
      // used as a generic public bucket. id + name + savedAt are required;
      // assumptions/templates/projects are opaque shape (engine validates
      // on load).
      allow write: if request.resource.data.id is string
                && request.resource.data.id == scenarioId
                && request.resource.data.name is string
                && request.resource.data.savedAt is number
                && request.resource.data.size() <= 50;
      allow delete: if true;
    }

    // Season snapshots: the live single-villa metrics published by the ops
    // app (villa-lev-admin hosting site) so this dashboard can render real
    // data without scraping the admin UI.
    //   - READ: open. The investor-facing dashboard is unauthenticated.
    //   - WRITE: never from this app. The ops app is the only writer and
    //     enforces admin-only at its rule layer (see the ops app's
    //     firestore.rules). Mirrored here for documentation; the
    //     authoritative ruleset on the project is whichever app deployed
    //     `firestore` last.
    match /seasonSnapshots/{snapshotId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
